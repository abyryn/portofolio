# Toleran terhadap peer dependency conflicts
legacy-peer-deps=true

# Jangan stop saat ada warning
strict-peer-deps=false

# Tetap install optional dependencies (default behavior, eksplisit)
# optional=true  <-- deprecated, gunakan --include=optional jika perlu

# Jangan jalankan audit otomatis saat install (manual saja pakai npm audit)
audit=false

# Jangan tampilkan funding notice
fund=false

# npx tidak tanya konfirmasi install package (penting di cPanel/CI)
yes=true
